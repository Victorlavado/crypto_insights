# API keys para Crypto Insights — todas free tier.
# Copia este archivo a .env (gitignored) y rellena con tus keys reales.

# GitHub Personal Access Token (scope: public_repo, read-only).
# Sin esto el github connector se salta por rate limit (60 req/h sin auth = insuficiente).
# Crear en: https://github.com/settings/tokens
CI_GITHUB_TOKEN=

# CoinGecko Demo (opcional, mejora rate limit).
# Free tier: 30 req/min, 10k req/MES.
# Crear en: https://www.coingecko.com/en/api/pricing
CI_COINGECKO_API_KEY=

# Alchemy (ETH/Base/Arbitrum top holders). Open Q1 — pendiente Fase 2 smart money.
# Free tier: 300M CU/mes.
# Crear en: https://www.alchemy.com/
CI_ALCHEMY_API_KEY=

# Moralis (alternativa/fallback a Alchemy).
# Free tier: ~25k CU/día.
# Crear en: https://moralis.com/
CI_MORALIS_API_KEY=

# Helius (Solana top holders DAS). Pendiente Fase 2 smart money.
# Free tier: 1M créditos/mes.
# Crear en: https://www.helius.dev/
CI_HELIUS_API_KEY=

# Etherscan v2 (multichain). Opcional.
# Free tier: 5 req/s, 100k/día.
# IMPORTANTE: cambio 1-jul-2026 en free tier — ver docs.
# Crear en: https://etherscan.io/myapikey
CI_ETHERSCAN_API_KEY=

# Comportamiento del batch
CI_BATCH_TIMEOUT_SECONDS=1800
CI_ORPHAN_BATCH_THRESHOLD_HOURS=2
CI_HEARTBEAT_INTERVAL_SECONDS=30

# Logging
CI_LOG_LEVEL=INFO
CI_LOG_FORMAT=json
